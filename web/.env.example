VITE_API_BASE=http://localhost:5000
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=Chatbot CRM
VITE_DEMO_MODE=false

# Android thermal printing via Cleanter local HTTP bridge.
VITE_CLEANTER_ENABLED=true
VITE_CLEANTER_BASE_URL=http://127.0.0.1:9100
VITE_CLEANTER_PRINT_PATH=/print
VITE_CLEANTER_TIMEOUT_MS=10000
VITE_CLEANTER_MAX_PAYLOAD_BYTES=256000
VITE_CLEANTER_SUPPORTS_CUT=false
