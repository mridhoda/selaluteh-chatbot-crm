# App
NODE_ENV=development
PORT=5000
PUBLIC_BASE_URL=http://localhost:5000
# Public web origin used by payment-provider browser return redirects.
PUBLIC_WEB_BASE_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-dev-only

# Database
DATA_SOURCE=supabase
SUPABASE_URL=https://hxeljduldgynligjioff.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
SUPABASE_DATABASE_URL=<supabase-database-url>
SUPABASE_ANON_KEY=<supabase-anon-key>

# Storage
LOCAL_UPLOAD_ROOT=server/uploads
PUBLIC_FILES_BASE_URL=http://localhost:5000/uploads

# AI providers
OPENAI_API_KEY=<openai-compatible-api-key>
OPENAI_BASE_URL=<optional-openai-compatible-base-url>
OPENAI_MODEL=<openai-compatible-model-name>
OPENAI_APP_NAME=SelaluTeh Chatbot CRM
OPENAI_REFERER=http://localhost:5173
GOOGLE_API_KEY=<google-api-key>
GEMINI_MODEL=gemini-2.5-flash

# Telegram / Meta
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
CHANNEL_CREDENTIAL_ENCRYPTION_KEY=<stable-channel-credential-key>
CHANNEL_CREDENTIAL_KEY_VERSION=v1
CHANNEL_CREDENTIAL_FINGERPRINT_PEPPER=<stable-fingerprint-pepper>
TELEGRAM_WEBHOOK_BODY_LIMIT=2mb
TELEGRAM_WEBHOOK_MAX_ATTEMPTS=8
TELEGRAM_WEBHOOK_RETRY_BASE_MS=1000
TELEGRAM_ALLOWED_UPDATES=message,callback_query
TELEGRAM_CONNECTION_RECONCILIATION_ENABLED=true
TELEGRAM_LEGACY_TOKEN_WEBHOOK_ENABLED=false
META_VERIFY_TOKEN=<meta-verify-token>
META_APP_SECRET=<meta-app-secret>
META_ACCESS_TOKEN=<meta-access-token>

# Payments
PAYMENT_PROVIDER=manual
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=<midtrans-server-key>
MIDTRANS_CLIENT_KEY=<midtrans-client-key>
PAYMENT_WEBHOOK_SECRET=<payment-webhook-secret>

# Xendit Test Mode Payment Sessions (server-only)
XENDIT_MODE=test
XENDIT_API_BASE_URL=https://api.xendit.co
XENDIT_SECRET_API_KEY=
XENDIT_WEBHOOK_VERIFICATION_TOKEN=
XENDIT_PAYMENT_COUNTRY=ID
XENDIT_PAYMENT_CURRENCY=IDR
XENDIT_PAYMENT_SESSION_MODE=PAYMENT_LINK
XENDIT_PAYMENT_CAPTURE_METHOD=AUTOMATIC
XENDIT_PAYMENT_SESSION_TTL_MINUTES=30

# Email
SMTP_URL=<smtp-url>
SMTP_FROM=no-reply@example.test

# Browser Web Push (desktop / Android web app)
# Generate with: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@example.test

# AI Agent Architecture (optional)
AI_DEFAULT_PROVIDER=local_openai_compatible
AI_DEFAULT_MODEL=gpt-4o-mini
AI_EMBEDDING_PROVIDER=ollama
AI_EMBEDDING_MODEL=nomic-embed-text
AI_MAX_INPUT_TOKENS=8000
AI_SUMMARY_MODEL=gpt-4o-mini
AI_MAX_TOOL_CALLS=10
AI_MAX_ITERATIONS=5
AI_RUN_RETENTION_DAYS=30
AI_TOOL_TRACE_RETENTION_DAYS=90
LOCAL_AI_BASE_URL=
LOCAL_AI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
