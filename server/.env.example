# App
NODE_ENV=development
PORT=5000
PUBLIC_BASE_URL=http://localhost:5000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-dev-only

# Database
MONGODB_URI=mongodb://localhost:27017/chatbot_crm

# Storage
LOCAL_UPLOAD_ROOT=server/uploads
PUBLIC_FILES_BASE_URL=http://localhost:5000/uploads

# AI providers
OPENAI_API_KEY=<openai-api-key>
GOOGLE_API_KEY=<google-api-key>

# Telegram / Meta
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
META_VERIFY_TOKEN=<meta-verify-token>
META_APP_SECRET=<meta-app-secret>
META_ACCESS_TOKEN=<meta-access-token>

# Payments
PAYMENT_PROVIDER=manual
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=<midtrans-server-key>
MIDTRANS_CLIENT_KEY=<midtrans-client-key>
XENDIT_SECRET_KEY=<xendit-secret-key>
PAYMENT_WEBHOOK_SECRET=<payment-webhook-secret>

# Email
SMTP_URL=<smtp-url>
SMTP_FROM=no-reply@example.test
